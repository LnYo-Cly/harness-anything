{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2024",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "jsx": "react-jsx",
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "src/renderer/App.tsx",
    "src/renderer/main.tsx",
    "src/renderer/theme.tsx",
    "src/renderer/api-client.ts",
    "src/renderer/task-data.ts",
    "src/renderer/task-adapter.ts",
    "src/renderer/views",
    "src/renderer/components",
    "src/renderer/graph",
    "src/renderer/model",
    "src/api/renderer-dto.ts"
  ],
  "references": [
    {
      "path": "../application"
    },
    {
      "path": "./tsconfig.renderer.json"
    }
  ]
}
