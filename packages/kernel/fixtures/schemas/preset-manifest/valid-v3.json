{
  "schema": "preset-manifest/v3",
  "id": "semantic-foundation",
  "title": "Semantic Foundation",
  "vertical": "software/coding",
  "version": "1.0.0",
  "kind": "process-action",
  "kernelVersionRange": {
    "min": "1.0.0",
    "maxExclusive": "2.0.0"
  },
  "capabilityImports": [],
  "entrypoints": {
    "audit": {
      "type": "script",
      "command": "scripts/audit.mjs",
      "intent": {
        "verb": "audit",
        "subject": "semantic-foundation"
      },
      "inputs": {
        "taskId": {
          "type": "task-ref",
          "required": true,
          "defaultFrom": "current-task"
        },
        "decisionId": {
          "type": "decision-ref",
          "required": false
        },
        "trackedArtifacts": {
          "type": "enum-list",
          "required": false,
          "values": ["runtime-events", "docmap"],
          "default": ["runtime-events", "docmap"]
        },
        "sourcePack": {
          "type": "string",
          "required": true
        }
      },
      "requires": [
        { "capability": "tasks", "version": "1", "select": { "scope": "all", "view": "identity-and-preset" } },
        { "capability": "decisions", "version": "1", "select": { "states": ["active"], "view": "canon-summary" } },
        { "capability": "adrs", "version": "1", "select": { "states": ["accepted", "active", "approved"], "view": "canon-summary" } },
        { "capability": "operating-docs", "version": "1", "select": { "collections": ["agents-guide", "governance", "standards"], "view": "text" } },
        { "capability": "task-artifacts", "version": "1", "select": { "taskFrom": "taskId", "artifactIds": ["evidence"] } },
        { "capability": "relation-graph", "version": "1", "select": { "scope": "decision-or-all", "decisionFrom": "decisionId", "view": "dossier" } },
        { "capability": "runtime-events", "version": "1", "select": { "view": "command-usage" } },
        { "capability": "generated-artifacts", "version": "1", "select": { "view": "presence-inventory", "familiesFrom": "trackedArtifacts" } },
        { "capability": "write-journal", "version": "1", "select": { "view": "presence-inventory" } },
        { "capability": "docmap", "version": "1", "select": { "view": "presence" } },
        { "capability": "external-source-pack", "version": "1", "select": { "packFrom": "sourcePack", "view": "files-with-provenance" } },
        { "capability": "repository-source", "version": "1", "select": { "collections": ["project-config", "gate-tooling", "product-source"], "view": "text-snapshot" } }
      ],
      "produces": [
        {
          "capability": "task-artifacts",
          "version": "1",
          "target": { "taskFrom": "current-task" },
          "artifacts": [
            {
              "id": "semantic-audit-report",
              "schema": "semantic-audit/v1",
              "mediaTypes": ["application/json", "text/markdown"],
              "cardinality": "one",
              "required": true
            }
          ]
        },
        {
          "capability": "task-documents",
          "version": "1",
          "target": { "taskFrom": "taskId" },
          "documents": [
            {
              "id": "semantic-audit-summary",
              "schema": "semantic-audit-summary/v1",
              "mediaTypes": ["text/markdown"],
              "cardinality": "one",
              "required": true
            }
          ]
        }
      ],
      "sideEffects": []
    }
  },
  "profiles": [
    {
      "id": "baseline",
      "title": "Baseline",
      "checkerProfile": "standard",
      "completionGates": ["ci", "code-doc-reconciliation"],
      "templateSelections": []
    }
  ],
  "defaultProfile": "baseline"
}
