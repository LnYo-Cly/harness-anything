{
  "schema": "vertical-definition/v1",
  "id": "software/coding",
  "title": "Software Coding",
  "version": "1.0.0",
  "entityKinds": [
    {
      "id": "task",
      "entityType": "lifecycle",
      "packageKind": "task-package/v2",
      "contractEntity": true
    },
    {
      "id": "decision",
      "entityType": "lifecycle",
      "packageKind": "decision-package/v1",
      "contractEntity": true
    },
    {
      "id": "fact",
      "entityType": "schema",
      "schemaRef": "schema://fact-record",
      "contractEntity": true
    }
  ],
  "contractEntityKinds": ["task", "decision", "fact"],
  "packageScaffolds": [
    {
      "entityKind": "task",
      "templateSelections": [
        {
          "slot": "task.flow",
          "templateRef": "template://planning/task-flow@1",
          "materializeAs": "task_flow.md",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          },
          "requiredWhen": {
            "profile": "baseline"
          }
        }
      ]
    },
    {
      "entityKind": "decision",
      "templateSelections": []
    }
  ],
  "repositoryScaffold": {
    "entityRoots": [
      { "entityKind": "task", "path": "{{paths.tasksRoot}}", "create": "init" },
      { "entityKind": "decision", "path": "{{paths.decisionsRoot}}", "create": "lazy" }
    ],
    "dirs": [
      { "path": "{{paths.authoredRoot}}/standards", "create": "init" },
      { "path": "{{paths.authoredRoot}}/context", "create": "init" },
      { "path": "{{paths.adrRoot}}", "create": "init" },
      { "path": "{{paths.sessionsRoot}}", "create": "lazy" }
    ],
    "seededDocs": [
      {
        "slot": "repository.governance",
        "templateRef": "template://planning/task-flow@1",
        "materializeAs": "{{paths.authoredRoot}}/standards/repo-governance.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      }
    ]
  },
  "scripts": [
    {
      "id": "vertical:software-coding:repository-audit",
      "type": "script",
      "command": "scripts/repository-audit.mjs",
      "reads": [],
      "writes": [],
      "inputs": {},
      "metadata": {
        "description": "Report the repository scaffold contract.",
        "purpose": "audit",
        "contractVersion": "script-entry/v1",
        "produces": []
      }
    }
  ],
  "templateSelections": [],
  "checkerProfile": "software-coding-standard",
  "projectionSchemas": [
    {
      "id": "task-frontmatter",
      "schemaRef": "schema://task-frontmatter"
    },
    {
      "id": "decision-frontmatter",
      "schemaRef": "schema://decision-frontmatter"
    },
    {
      "id": "fact-record",
      "schemaRef": "schema://fact-record"
    }
  ]
}
