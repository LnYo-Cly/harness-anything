{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness-anything.dev/schemas/task-frontmatter.schema.json",
  "x-harness-schema-id": "task-frontmatter",
  "title": "Task Frontmatter v2",
  "type": "object",
  "required": [
    "schema",
    "task_id",
    "title",
    "lifecycle",
    "packageDisposition",
    "vertical",
    "preset",
    "provenance"
  ],
  "properties": {
    "schema": {
      "const": "task-package/v2"
    },
    "task_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "lifecycle": {
      "type": "object",
      "required": [
        "bindingSchema",
        "engine",
        "ref",
        "titleSnapshot",
        "url",
        "bindingCreatedAt",
        "bindingFingerprint"
      ],
      "properties": {
        "bindingSchema": {
          "const": "lifecycle-binding/v1"
        },
        "engine": {
          "type": "string"
        },
        "status": {
          "enum": [
            "planned",
            "active",
            "blocked",
            "in_review",
            "done",
            "cancelled"
          ]
        },
        "ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "titleSnapshot": {
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "bindingCreatedAt": {
          "type": "string"
        },
        "bindingFingerprint": {
          "type": "string",
          "pattern": "^sha256:"
        }
      }
    },
    "packageDisposition": {
      "enum": [
        "active",
        "archived",
        "tombstoned"
      ]
    },
    "vertical": {
      "type": "string"
    },
    "preset": {
      "type": "string"
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/provenanceEntry"
      }
    },
    "profile": {
      "type": "string"
    },
    "createdBy": {
      "type": "object",
      "required": [
        "name",
        "email"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "nonBlankString": {
      "type": "string",
      "pattern": "\\S"
    },
    "provenanceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime",
        "sessionId",
        "boundAt"
      ],
      "properties": {
        "runtime": {
          "enum": [
            "human",
            "claude-code",
            "codex",
            "zcode",
            "antigravity"
          ]
        },
        "sessionId": {
          "$ref": "#/$defs/nonBlankString"
        },
        "boundAt": {
          "$ref": "#/$defs/nonBlankString"
        }
      }
    }
  }
}
