{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness-anything.dev/schemas/preset-manifest.schema.json",
  "x-harness-schema-id": "preset-manifest",
  "title": "Preset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "title", "vertical", "version", "kernelVersionRange", "capabilityImports", "profiles", "defaultProfile"],
  "properties": {
    "schema": { "enum": ["preset-manifest/v1", "preset-manifest/v2"] },
    "id": { "type": "string" },
    "title": { "type": "string" },
    "vertical": { "type": "string" },
    "version": { "type": "string" },
    "kind": { "enum": ["template-content", "process-action"] },
    "extends": { "type": "string" },
    "policyPath": {
      "type": "string",
      "pattern": "^\\{\\{paths\\.authoredRoot\\}\\}/policies/presets/[A-Za-z0-9][A-Za-z0-9._-]*\\.policy\\.json$"
    },
    "kernelVersionRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min"],
      "properties": {
        "min": { "type": "string" },
        "maxExclusive": { "type": "string" }
      }
    },
    "capabilityImports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "version", "required"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "enum": ["checker", "scaffold", "projection", "command", "template"] },
          "version": { "type": "string" },
          "required": { "type": "boolean" }
        }
      }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/entrypoint" }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "checkerProfile", "templateSelections"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "checkerProfile": { "type": "string" },
          "templateSelections": {
            "type": "array",
            "items": { "$ref": "#/$defs/templateSelection" }
          },
          "capabilityImports": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "version"],
              "properties": {
                "id": { "type": "string" },
                "version": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "defaultProfile": { "type": "string" }
  },
  "$defs": {
    "templateSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot", "templateRef", "materializeAs", "localePolicy"],
      "properties": {
        "slot": { "type": "string" },
        "templateRef": { "type": "string" },
        "materializeAs": { "type": "string" },
        "localePolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["prefer", "fallback"],
          "properties": {
            "prefer": { "enum": ["project", "preset", "explicit"] },
            "fallback": { "enum": ["zh-CN", "en-US"] }
          }
        },
        "requiredWhen": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
    ,
    "entrypoint": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "writes", "templates"],
          "properties": {
            "type": { "const": "template" },
            "writes": { "type": "array", "items": { "type": "string" } },
            "templates": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "command", "writes"],
          "properties": {
            "type": { "const": "script" },
            "command": { "type": "string" },
            "reads": { "type": "array", "items": { "type": "string" } },
            "writes": { "type": "array", "items": { "type": "string" } },
            "inputs": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        }
      ]
    }
  }
}
