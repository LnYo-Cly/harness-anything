{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness-anything.dev/schemas/template-catalog.schema.json",
  "x-harness-schema-id": "template-catalog",
  "title": "Template Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "package", "documents"],
  "properties": {
    "schema": { "const": "template-catalog/v2" },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "version", "owner", "locales"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "version": { "type": "string" },
        "owner": { "type": "string" },
        "locales": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["zh-CN", "en-US"] }
        }
      }
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version", "documentKind", "slot", "materializeAs", "frontmatterSchema", "requiredAnchors", "sectionPermissions", "fallbackLocale", "locales"],
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "string" },
          "documentKind": { "type": "string" },
          "slot": { "type": "string" },
          "materializeAs": { "type": "string" },
          "frontmatterSchema": { "type": "string" },
          "requiredAnchors": {
            "type": "array",
            "items": { "type": "string" }
          },
          "sectionPermissions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["anchor", "writeMode"],
              "properties": {
                "anchor": { "type": "string" },
                "writeMode": { "enum": ["free-prose", "machine-written", "forbidden"] },
                "semanticClass": { "enum": ["host-prose-only", "entity-bearing"] }
              }
            }
          },
          "fallbackLocale": { "enum": ["zh-CN", "en-US"] },
          "locales": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["locale", "anchors", "bodyPath"],
              "properties": {
                "locale": { "enum": ["zh-CN", "en-US"] },
                "anchors": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "bodyPath": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
