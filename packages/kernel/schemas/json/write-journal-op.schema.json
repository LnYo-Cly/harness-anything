{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema",
    "opId",
    "entityId",
    "kind",
    "at",
    "actor",
    "principalSource",
    "executorSource"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "enum": [
        "write-journal/v2"
      ]
    },
    "opId": {
      "type": "string"
    },
    "entityId": {
      "anyOf": [
        {
          "type": "string",
          "title": "`task/${string}`",
          "description": "a template literal",
          "pattern": "^task\\/[\\s\\S]*?$"
        },
        {
          "type": "string",
          "title": "`decision/${string}`",
          "description": "a template literal",
          "pattern": "^decision\\/[\\s\\S]*?$"
        },
        {
          "type": "string",
          "title": "`module/${string}`",
          "description": "a template literal",
          "pattern": "^module\\/[\\s\\S]*?$"
        },
        {
          "type": "string",
          "title": "`entity/${string}/${string}`",
          "description": "a template literal",
          "pattern": "^entity\\/[\\s\\S]*?\\/[\\s\\S]*?$"
        }
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "package_create",
        "transition_local",
        "progress_append",
        "doc_stage",
        "task_tree_stage",
        "doc_write",
        "doc_sync_submit",
        "code_doc_reconcile",
        "package_archive",
        "package_tombstone",
        "package_reopen",
        "package_supersede",
        "package_delete_hard",
        "decision_propose",
        "decision_accept",
        "decision_reject",
        "decision_defer",
        "decision_supersede",
        "decision_amend",
        "decision_relate",
        "decision_retire",
        "fact_invalidate",
        "relation_retire",
        "relation_replace",
        "module_registry_write",
        "module_scaffold_write",
        "script_ingest",
        "machine_artifact_write",
        "machine_artifact_append_jsonl"
      ]
    },
    "at": {
      "type": "string"
    },
    "payloadRef": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "payload": {
      "type": "object",
      "required": [],
      "properties": {},
      "additionalProperties": {
        "$id": "/schemas/unknown",
        "title": "unknown"
      }
    },
    "authorityIntegrity": {
      "type": "object",
      "required": [
        "schema",
        "semanticRequestDigest",
        "semanticMutationSetDigest",
        "mutationRegistryVersion",
        "actorAxesBindingDigest",
        "canonicalMutationSet"
      ],
      "properties": {
        "schema": {
          "type": "string",
          "enum": [
            "authority-operation-integrity/v2"
          ]
        },
        "semanticRequestDigest": {
          "type": "string",
          "description": "a string matching the pattern ^[0-9a-f]{64}$",
          "pattern": "^[0-9a-f]{64}$"
        },
        "semanticMutationSetDigest": {
          "type": "string",
          "description": "a string matching the pattern ^[0-9a-f]{64}$",
          "pattern": "^[0-9a-f]{64}$"
        },
        "mutationRegistryVersion": {
          "type": "integer",
          "description": "a number less than or equal to 4294967295",
          "title": "lessThanOrEqualTo(4294967295)",
          "minimum": 0,
          "maximum": 4294967295
        },
        "actorAxesBindingDigest": {
          "type": "string",
          "description": "a string matching the pattern ^[0-9a-f]{64}$",
          "pattern": "^[0-9a-f]{64}$"
        },
        "canonicalMutationSet": {
          "type": "object",
          "required": [
            "registryVersion",
            "mutations"
          ],
          "properties": {
            "registryVersion": {
              "type": "integer",
              "description": "a number less than or equal to 4294967295",
              "title": "lessThanOrEqualTo(4294967295)",
              "minimum": 0,
              "maximum": 4294967295
            },
            "mutations": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "entity",
                  "action"
                ],
                "properties": {
                  "entity": {
                    "type": "object",
                    "required": [
                      "registryVersion",
                      "entityKind",
                      "canonicalRef"
                    ],
                    "properties": {
                      "registryVersion": {
                        "type": "integer",
                        "description": "a number less than or equal to 4294967295",
                        "title": "lessThanOrEqualTo(4294967295)",
                        "minimum": 0,
                        "maximum": 4294967295
                      },
                      "entityKind": {
                        "type": "string",
                        "description": "a string matching the pattern \\S",
                        "pattern": "\\S"
                      },
                      "canonicalRef": {
                        "type": "string",
                        "description": "a string matching the pattern \\S",
                        "pattern": "\\S"
                      }
                    },
                    "additionalProperties": false
                  },
                  "action": {
                    "type": "object",
                    "required": [
                      "registryVersion",
                      "action"
                    ],
                    "properties": {
                      "registryVersion": {
                        "type": "integer",
                        "description": "a number less than or equal to 4294967295",
                        "title": "lessThanOrEqualTo(4294967295)",
                        "minimum": 0,
                        "maximum": 4294967295
                      },
                      "action": {
                        "type": "string",
                        "description": "a string matching the pattern \\S",
                        "pattern": "\\S"
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "actor": {
      "type": "object",
      "required": [
        "principal",
        "executor"
      ],
      "properties": {
        "principal": {
          "type": "object",
          "required": [
            "kind",
            "personId"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "person"
              ]
            },
            "personId": {
              "type": "string",
              "description": "a string matching the pattern \\S",
              "pattern": "\\S"
            }
          },
          "additionalProperties": false
        },
        "executor": {
          "anyOf": [
            {
              "type": "object",
              "required": [
                "kind",
                "id"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "agent"
                  ]
                },
                "id": {
                  "type": "string",
                  "description": "a string matching the pattern \\S",
                  "pattern": "\\S"
                }
              },
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "principalSource": {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "providerId",
            "credentialFingerprint"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "daemon-authenticated"
              ]
            },
            "providerId": {
              "type": "string",
              "description": "a string matching the pattern \\S",
              "pattern": "\\S"
            },
            "credentialFingerprint": {
              "type": "string",
              "description": "a string matching the pattern \\S",
              "pattern": "\\S"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind",
            "authority",
            "authoritySha256"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "local-configured"
              ]
            },
            "authority": {
              "type": "string",
              "enum": [
                "persons.yaml",
                "people.yaml-legacy",
                "harness.yaml"
              ]
            },
            "authoritySha256": {
              "type": "string",
              "description": "a string matching the pattern \\S",
              "pattern": "\\S"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind",
            "evidenceRef"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "migration"
              ]
            },
            "evidenceRef": {
              "type": "string",
              "description": "a string matching the pattern \\S",
              "pattern": "\\S"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "executorSource": {
      "type": "string",
      "enum": [
        "client-asserted",
        "none"
      ]
    }
  },
  "additionalProperties": false,
  "$id": "https://harness-anything.dev/schemas/write-journal-op.schema.json",
  "x-harness-schema-id": "write-journal-op",
  "title": "Write Journal Op v2",
  "allOf": [
    {
      "if": {
        "properties": {
          "actor": {
            "properties": {
              "executor": {
                "type": "null"
              }
            },
            "required": [
              "executor"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "executorSource": {
            "const": "none"
          }
        }
      },
      "else": {
        "properties": {
          "executorSource": {
            "const": "client-asserted"
          }
        }
      }
    }
  ]
}
