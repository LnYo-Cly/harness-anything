{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "x-harness-schema-id": "docmap",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "documents"
  ],
  "properties": {
    "schema": {
      "const": "docmap/v1"
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "kind",
          "scope",
          "owner",
          "brief"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/@-]*$"
          },
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//).+$"
          },
          "kind": {
            "enum": [
              "adr",
              "standard",
              "architecture",
              "roadmap",
              "task",
              "research",
              "other"
            ]
          },
          "scope": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "modules",
              "productLines"
            ],
            "properties": {
              "modules": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "productLines": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "owner": {
            "type": "string"
          },
          "brief": {
            "type": "string"
          },
          "supersedes": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/@-]*$"
            }
          },
          "supersededBy": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/@-]*$"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
