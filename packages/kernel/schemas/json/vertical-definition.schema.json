{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness-anything.dev/schemas/vertical-definition.schema.json",
  "x-harness-schema-id": "vertical-definition",
  "title": "Vertical Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "title", "version", "entityKinds", "contractEntityKinds", "packageScaffolds", "repositoryScaffold", "scripts", "templateSelections", "checkerProfile", "projectionSchemas"],
  "properties": {
    "schema": { "const": "vertical-definition/v1" },
    "id": { "type": "string" },
    "title": { "type": "string" },
    "version": { "type": "string" },
    "entityKinds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "entityType", "packageKind", "contractEntity"],
            "properties": {
              "id": { "type": "string" },
              "entityType": { "const": "lifecycle" },
              "packageKind": { "type": "string" },
              "contractEntity": { "type": "boolean" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "entityType", "schemaRef", "contractEntity"],
            "properties": {
              "id": { "type": "string" },
              "entityType": { "const": "schema" },
              "schemaRef": { "type": "string" },
              "contractEntity": { "type": "boolean" }
            }
          }
        ]
      }
    },
    "contractEntityKinds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "packageScaffolds": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entityKind", "templateSelections"],
        "properties": {
          "entityKind": { "type": "string" },
          "templateSelections": {
            "type": "array",
            "items": { "$ref": "#/$defs/templateSelection" }
          }
        }
      }
    },
    "repositoryScaffold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entityRoots", "dirs", "seededDocs"],
      "properties": {
        "entityRoots": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["entityKind", "path", "create"],
            "properties": {
              "entityKind": { "type": "string" },
              "path": { "type": "string" },
              "create": { "enum": ["init", "lazy"] }
            }
          }
        },
        "dirs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "create"],
            "properties": {
              "path": { "type": "string" },
              "create": { "enum": ["init", "lazy"] }
            }
          }
        },
        "seededDocs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "body"],
            "properties": {
              "path": { "type": "string" },
              "body": { "type": "string" },
              "overwrite": { "type": "boolean" }
            }
          }
        }
      }
    },
    "scripts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "command", "reads", "writes", "inputs", "metadata"],
        "properties": {
          "id": { "type": "string" },
          "type": { "const": "script" },
          "command": { "type": "string" },
          "reads": { "type": "array", "items": { "type": "string" } },
          "writes": { "type": "array", "items": { "type": "string" } },
          "inputs": { "type": "object", "additionalProperties": { "type": "string" } },
          "metadata": {
            "type": "object",
            "additionalProperties": false,
            "required": ["description", "purpose", "contractVersion", "produces"],
            "properties": {
              "description": { "type": "string" },
              "purpose": { "enum": ["scaffold", "generate", "transform", "audit"] },
              "contractVersion": { "const": "script-entry/v1" },
              "produces": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "templateSelections": {
      "type": "array",
      "items": { "$ref": "#/$defs/templateSelection" }
    },
    "checkerProfile": { "type": "string" },
    "projectionSchemas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "schemaRef"],
        "properties": {
          "id": { "type": "string" },
          "schemaRef": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "templateSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot", "templateRef", "materializeAs", "localePolicy"],
      "properties": {
        "slot": { "type": "string" },
        "templateRef": { "type": "string" },
        "materializeAs": { "type": "string" },
        "localePolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["prefer", "fallback"],
          "properties": {
            "prefer": { "enum": ["project", "preset", "explicit"] },
            "fallback": { "enum": ["zh-CN", "en-US"] }
          }
        },
        "requiredWhen": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
