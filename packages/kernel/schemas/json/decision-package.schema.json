{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness-anything.dev/schemas/decision-package.schema.json",
  "x-harness-schema-id": "decision-package",
  "title": "Decision Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "decision_id",
    "title",
    "state",
    "riskTier",
    "urgency",
    "vertical",
    "preset",
    "applies_to",
    "proposedAt",
    "provenance",
    "question",
    "chosen",
    "rejected",
    "claims",
    "relations"
  ],
  "properties": {
    "schema": { "const": "decision-package/v1" },
    "decision_id": { "type": "string", "pattern": "^dec_[A-Za-z0-9_-]+$" },
    "title": { "$ref": "#/$defs/nonBlankString" },
    "state": { "enum": ["proposed", "active", "rejected", "deferred", "retired"] },
    "riskTier": { "enum": ["low", "medium", "high"] },
    "urgency": { "enum": ["low", "medium", "high"] },
    "vertical": { "$ref": "#/$defs/nonBlankString" },
    "preset": { "$ref": "#/$defs/nonBlankString" },
    "decisionClass": { "const": "standing-policy" },
    "applies_to": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modules", "productLines"],
      "properties": {
        "modules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "productLines": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "proposedAt": { "$ref": "#/$defs/nonBlankString" },
    "decidedAt": { "type": "string" },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/provenanceEntry" }
    },
    "question": { "$ref": "#/$defs/nonBlankString" },
    "chosen": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/decisionAnchor" }
    },
    "rejected": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rejectedDecisionAnchor" }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/decisionClaim" }
    },
    "relations": {
      "type": "array",
      "items": { "$ref": "#/$defs/relationRecord" }
    }
  },
  "$defs": {
    "nonBlankString": {
      "type": "string",
      "pattern": "\\S"
    },
    "actorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "enum": ["agent", "human", "system"] },
        "id": { "type": "string" }
      }
    },
    "provenanceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "sessionId", "boundAt"],
      "properties": {
        "runtime": {
          "enum": [
            "human",
            "claude-code",
            "codex",
            "zcode",
            "antigravity"
          ]
        },
        "sessionId": { "$ref": "#/$defs/nonBlankString" },
        "boundAt": { "$ref": "#/$defs/nonBlankString" }
      }
    },
    "decisionAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
        "text": { "$ref": "#/$defs/nonBlankString" },
        "load_bearing": { "type": "boolean" }
      }
    },
    "decisionClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
        "text": { "$ref": "#/$defs/nonBlankString" },
        "load_bearing": { "type": "boolean" },
        "fulfillment": { "enum": ["evidenced", "delivered", "standing-policy"] }
      }
    },
    "rejectedDecisionAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "why_not"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
        "text": { "$ref": "#/$defs/nonBlankString" },
        "why_not": { "$ref": "#/$defs/nonBlankString" }
      }
    },
    "entityRef": {
      "type": "string",
      "pattern": "^(?:(?:task|decision)/[A-Za-z0-9_-]+(?:/[A-Za-z][A-Za-z0-9_-]*)?|fact/[A-Za-z0-9_-]+/F-[A-Za-z0-9_-]+)$"
    },
    "relationRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relation_id", "source", "target", "type", "strength", "direction", "origin", "rationale", "state"],
      "properties": {
        "relation_id": { "type": "string", "pattern": "^rel_[a-f0-9]{16}$" },
        "source": { "$ref": "#/$defs/entityRef" },
        "target": { "$ref": "#/$defs/entityRef" },
        "type": { "enum": ["supports", "supersedes", "refines", "narrows", "derives", "blocks", "relates", "implements", "depends-on", "produces", "evidences", "evidenced-by", "refutes", "invalidated-by", "supersedes-fact"] },
        "strength": { "enum": ["strong", "weak"] },
        "direction": { "enum": ["directed", "undirected"] },
        "origin": { "enum": ["declared", "imported_snapshot", "generated", "inferred"] },
        "rationale": { "$ref": "#/$defs/nonBlankString" },
        "state": { "enum": ["active", "retired", "deleted"] }
      }
    }
  }
}
