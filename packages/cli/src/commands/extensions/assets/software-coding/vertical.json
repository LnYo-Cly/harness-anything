{
  "schema": "vertical-definition/v1",
  "id": "software/coding",
  "title": "Software Coding",
  "version": "1.0.0",
  "entityKinds": [
    {
      "id": "task",
      "entityType": "lifecycle",
      "packageKind": "task-package/v2",
      "contractEntity": true
    },
    {
      "id": "decision",
      "entityType": "lifecycle",
      "packageKind": "decision-package/v1",
      "contractEntity": true
    },
    {
      "id": "fact",
      "entityType": "schema",
      "schemaRef": "schema://fact-record",
      "contractEntity": true
    }
  ],
  "contractEntityKinds": [
    "task",
    "decision",
    "fact"
  ],
  "packageScaffolds": [
    {
      "entityKind": "task",
      "templateSelections": [
        {
          "slot": "task.plan",
          "templateRef": "template://planning/task-plan@1",
          "materializeAs": "task_plan.md",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          }
        },
        {
          "slot": "task.progress",
          "templateRef": "template://planning/progress@1",
          "materializeAs": "progress.md",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          }
        },
        {
          "slot": "task.facts",
          "templateRef": "template://planning/keep-file@1",
          "materializeAs": "facts.md",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          }
        },
        {
          "slot": "task.review",
          "templateRef": "template://planning/review@1",
          "materializeAs": "review.md",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          }
        },
        {
          "slot": "task.closeout",
          "templateRef": "template://planning/closeout@1",
          "materializeAs": "closeout.md",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          }
        },
        {
          "slot": "task.artifacts.keep",
          "templateRef": "template://planning/keep-file@1",
          "materializeAs": "artifacts/.gitkeep",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          }
        },
        {
          "slot": "task.references.keep",
          "templateRef": "template://planning/keep-file@1",
          "materializeAs": "references/.gitkeep",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          }
        }
      ]
    },
    {
      "entityKind": "decision",
      "templateSelections": []
    }
  ],
  "repositoryScaffold": {
    "entityRoots": [
      {
        "entityKind": "task",
        "path": "{{paths.tasksRoot}}",
        "create": "init"
      },
      {
        "entityKind": "decision",
        "path": "{{paths.decisionsRoot}}",
        "create": "lazy"
      }
    ],
    "dirs": [
      {
        "path": "{{paths.authoredRoot}}",
        "create": "init"
      },
      {
        "path": "{{paths.authoredRoot}}/standards",
        "create": "init"
      },
      {
        "path": "{{paths.authoredRoot}}/context",
        "create": "init"
      },
      {
        "path": "{{paths.authoredRoot}}/context/architecture",
        "create": "init"
      },
      {
        "path": "{{paths.adrRoot}}",
        "create": "init"
      },
      {
        "path": "{{paths.milestonesRoot}}",
        "create": "init"
      }
    ],
    "seededDocs": [
      {
        "slot": "repository.governance",
        "templateRef": "template://repository/repo-governance@1",
        "materializeAs": "{{paths.authoredRoot}}/standards/repo-governance.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      },
      {
        "slot": "repository.agent.entry",
        "templateRef": "template://repository/agent-entry@1",
        "materializeAs": "{{paths.rootDir}}/AGENTS.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      },
      {
        "slot": "repository.claude.entry",
        "templateRef": "template://repository/claude-entry@1",
        "materializeAs": "{{paths.rootDir}}/CLAUDE.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      }
    ]
  },
  "scripts": [
    {
      "id": "vertical:software-coding:repository-audit",
      "type": "script",
      "command": "scripts/repository-audit.mjs",
      "reads": [],
      "writes": [],
      "inputs": {},
      "metadata": {
        "description": "Report the bundled software/coding repository scaffold contract.",
        "purpose": "audit",
        "contractVersion": "script-entry/v1",
        "produces": []
      }
    },
    {
      "id": "vertical:software-coding:adr-seed",
      "type": "script",
      "command": "scripts/adr-seed.mjs",
      "reads": [],
      "writes": [
        "{{paths.adrRoot}}/**"
      ],
      "inputs": {
        "locale": "en-US"
      },
      "metadata": {
        "description": "Seed repository ADR README and template documents.",
        "purpose": "scaffold",
        "contractVersion": "script-entry/v1",
        "produces": [
          "{{paths.adrRoot}}/README.md",
          "{{paths.adrRoot}}/0000-template.md"
        ]
      }
    }
  ],
  "templateSelections": [],
  "checkerProfile": "software-coding-standard",
  "projectionSchemas": [
    {
      "id": "task-frontmatter",
      "schemaRef": "schema://task-frontmatter"
    },
    {
      "id": "decision-frontmatter",
      "schemaRef": "schema://decision-frontmatter"
    },
    {
      "id": "fact-record",
      "schemaRef": "schema://fact-record"
    }
  ]
}
