{
  "schema": "vertical-definition/v1",
  "id": "software/coding",
  "title": "Software Coding",
  "version": "1.2.0",
  "entityFieldExtensions": [
    {
      "extends": "task",
      "field": "taskClass",
      "kind": "enum-facet",
      "values": ["milestone", "epic"],
      "default": null,
      "mutability": "amendable",
      "projection": {
        "column": "task_class",
        "queryable": true
      },
      "reason": "coding vertical rendering height: milestone or epic"
    }
  ],
  "entityKinds": [
    {
      "id": "task",
      "entityType": "lifecycle",
      "packageKind": "task-package/v2",
      "contractEntity": true
    },
    {
      "id": "decision",
      "entityType": "lifecycle",
      "packageKind": "decision-package/v1",
      "contractEntity": true
    },
    {
      "id": "fact",
      "entityType": "schema",
      "schemaRef": "schema://fact-record",
      "contractEntity": true
    }
  ],
  "contractEntityKinds": [
    "task",
    "decision",
    "fact"
  ],
  "packageScaffolds": [
    {
      "entityKind": "task",
      "templateSelections": [
        {
          "slot": "task.plan",
          "templateRef": "template://planning/task-plan@1",
          "materializeAs": "task_plan.md",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          }
        },
        {
          "slot": "task.facts",
          "templateRef": "template://planning/facts@1",
          "materializeAs": "facts.md",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          }
        },
        {
          "slot": "task.closeout",
          "templateRef": "template://planning/closeout@1",
          "materializeAs": "closeout.md",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          }
        },
        {
          "slot": "task.artifacts.keep",
          "templateRef": "template://planning/keep-file@1",
          "materializeAs": "artifacts/.gitkeep",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          }
        }
      ]
    },
    {
      "entityKind": "decision",
      "templateSelections": []
    }
  ],
  "repositoryScaffold": {
    "entityRoots": [
      {
        "entityKind": "task",
        "path": "{{paths.tasksRoot}}",
        "create": "init"
      },
      {
        "entityKind": "decision",
        "path": "{{paths.decisionsRoot}}",
        "create": "lazy"
      }
    ],
    "dirs": [
      {
        "path": "{{paths.authoredRoot}}",
        "create": "init"
      },
      {
        "path": "{{paths.authoredRoot}}/standards",
        "create": "init"
      },
      {
        "path": "{{paths.authoredRoot}}/context",
        "create": "init"
      },
      {
        "path": "{{paths.authoredRoot}}/context/architecture",
        "create": "init"
      },
      {
        "path": "{{paths.adrRoot}}",
        "create": "init"
      },
      {
        "path": "{{paths.milestonesRoot}}",
        "create": "init"
      }
    ],
    "seededDocs": [
      {
        "slot": "repository.governance",
        "templateRef": "template://repository/repo-governance@1",
        "materializeAs": "{{paths.authoredRoot}}/standards/repo-governance.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      },
      {
        "slot": "repository.claude.entry",
        "templateRef": "template://repository/claude-entry@1",
        "materializeAs": "{{paths.rootDir}}/CLAUDE.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      },
      {
        "slot": "repository.adr.readme",
        "templateRef": "template://repository/adr-readme@1",
        "materializeAs": "{{paths.adrRoot}}/README.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      },
      {
        "slot": "repository.decisions.readme",
        "templateRef": "template://repository/decisions-readme@1",
        "materializeAs": "{{paths.decisionsRoot}}/README.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      },
      {
        "slot": "repository.milestones.readme",
        "templateRef": "template://repository/milestones-readme@1",
        "materializeAs": "{{paths.milestonesRoot}}/README.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      },
      {
        "slot": "repository.sessions.readme",
        "templateRef": "template://repository/sessions-readme@1",
        "materializeAs": "{{paths.sessionsRoot}}/README.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      },
      {
        "slot": "repository.standards.readme",
        "templateRef": "template://repository/standards-readme@1",
        "materializeAs": "{{paths.standardsRoot}}/README.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      },
      {
        "slot": "repository.context.readme",
        "templateRef": "template://repository/context-readme@1",
        "materializeAs": "{{paths.contextRoot}}/README.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      },
      {
        "slot": "repository.architecture.readme",
        "templateRef": "template://repository/architecture-readme@1",
        "materializeAs": "{{paths.contextRoot}}/architecture/README.md",
        "localePolicy": {
          "prefer": "project",
          "fallback": "en-US"
        }
      }
    ],
    "agentsEntry": {
      "materializeAs": "{{paths.rootDir}}/AGENTS.md",
      "localePolicy": {
        "prefer": "project",
        "fallback": "en-US"
      },
      "baseRef": "template://repository/agent-base@1",
      "overlayRef": "template://repository/agent-overlay@1",
      "repoSpecificsAnchor": "## Repository Specifics"
    }
  },
  "scripts": [
    {
      "id": "vertical:software-coding:architecture-init",
      "type": "script",
      "command": "scripts/architecture-init.mjs",
      "reads": ["{{outputRoot}}/architecture/**"],
      "writes": ["{{outputRoot}}/architecture/**"],
      "inputs": {},
      "metadata": {
        "description": "Explicitly materialize the opt-in repository architecture manifest and LikeC4 scaffold without overwriting authored content.",
        "purpose": "scaffold",
        "contractVersion": "script-entry/v1",
        "produces": ["{{outputRoot}}/architecture/**"]
      }
    },
    {
      "id": "vertical:software-coding:architecture-snapshot",
      "type": "script",
      "command": "scripts/architecture-snapshot.mjs",
      "reads": ["{{paths.authoredRoot}}/context/architecture/**"],
      "writes": ["{{outputRoot}}/artifacts/architecture/**"],
      "inputs": {},
      "metadata": {
        "description": "Run fixed declared architecture adapters and write a reproducible code-fact snapshot as a task artifact.",
        "purpose": "generate",
        "contractVersion": "script-entry/v1",
        "produces": ["{{outputRoot}}/artifacts/architecture/**"]
      }
    },
    {
      "id": "vertical:software-coding:architecture-check",
      "type": "script",
      "command": "scripts/architecture-check.mjs",
      "reads": [
        "{{paths.authoredRoot}}/context/architecture/**",
        "{{outputRoot}}/artifacts/architecture/**"
      ],
      "writes": [],
      "inputs": {},
      "metadata": {
        "description": "Return deterministic architecture configuration, tool, freshness, and drift state without joining ordinary repository checks.",
        "purpose": "audit",
        "contractVersion": "script-entry/v1",
        "produces": []
      }
    },
    {
      "id": "vertical:software-coding:repository-audit",
      "type": "script",
      "command": "scripts/repository-audit.mjs",
      "reads": [],
      "writes": [],
      "inputs": {},
      "metadata": {
        "description": "Report the bundled software/coding repository scaffold contract.",
        "purpose": "audit",
        "contractVersion": "script-entry/v1",
        "produces": []
      }
    },
    {
      "id": "vertical:software-coding:adr-seed",
      "type": "script",
      "command": "scripts/adr-seed.mjs",
      "reads": [],
      "writes": [
        "{{paths.adrRoot}}/**"
      ],
      "inputs": {
        "locale": "en-US"
      },
      "metadata": {
        "description": "Seed repository ADR README and template documents.",
        "purpose": "scaffold",
        "contractVersion": "script-entry/v1",
        "produces": [
          "{{paths.adrRoot}}/README.md",
          "{{paths.adrRoot}}/0000-template.md"
        ]
      }
    },
    {
      "id": "vertical:software-coding:adr-render",
      "type": "script",
      "command": "scripts/adr-render.mjs",
      "reads": [
        "{{paths.decisionsRoot}}/**",
        "{{paths.adrRoot}}/**"
      ],
      "writes": [
        "{{paths.adrRoot}}/**"
      ],
      "inputs": {
        "locale": "en-US"
      },
      "metadata": {
        "description": "Render an ADR document from a decision entity (decision is SoT).",
        "purpose": "generate",
        "contractVersion": "script-entry/v1",
        "produces": [
          "{{paths.adrRoot}}/*.md"
        ]
      }
    },
    {
      "id": "vertical:software-coding:decision-conformance",
      "type": "script",
      "command": "scripts/decision-conformance-check.mjs",
      "reads": [
        "{{paths.authoredRoot}}/**",
        "{{paths.localRoot}}/**"
      ],
      "writes": [],
      "inputs": {},
      "metadata": {
        "description": "Check decision conformance across task derivation, relation coverage, fact coverage, supersession, and proposed-decision drift.",
        "purpose": "audit",
        "kind": "check",
        "contractVersion": "script-entry/v1",
        "produces": []
      }
    }
  ],
  "templateSelections": [],
  "checkerProfile": "software-coding-standard",
  "projectionSchemas": [
    {
      "id": "task-frontmatter",
      "schemaRef": "schema://task-frontmatter"
    },
    {
      "id": "decision-frontmatter",
      "schemaRef": "schema://decision-frontmatter"
    },
    {
      "id": "fact-record",
      "schemaRef": "schema://fact-record"
    }
  ]
}
